# ──── Application ────
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-use-random-64-char-string
API_PORT=8000

# ──── PostgreSQL ────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meeting_trans
POSTGRES_USER=meeting_trans
POSTGRES_PASSWORD=change-me

# ──── Redis ────
REDIS_URL=redis://localhost:6379/0

# ──── LiveKit ────
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Used by the LiveKit Agents translation worker.
LIVEKIT_URL=ws://localhost:7880
# Used by the API's LiveKit health checks.
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_PUBLIC_WS_URL=ws://localhost:7880

# ──── OpenAI ────
OPENAI_API_KEY=sk-change-me
OPENAI_REALTIME_TRANSLATE_MODEL=gpt-realtime-translate
OPENAI_REALTIME_TRANSCRIBE_MODEL=gpt-realtime-whisper
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_DELAY=low
OPENAI_TRANSCRIPTION_SILENCE_COMMIT_MS=500
OPENAI_TRANSLATE_FINAL_SILENCE_MS=700
OPENAI_TRANSLATE_OUTPUT_IDLE_MS=1500
OPENAI_TRANSLATE_LATE_REVISION_MS=10000

# ──── Translation worker ────
TRANSLATION_PROVIDER=openai-hybrid
OPENAI_REALTIME_TRANSLATE_SOURCE_LANGUAGES=en
TRANSLATION_PARTIAL_DEBOUNCE_MS=150
TRANSLATION_PARTIAL_MIN_CHARS=8
TRANSLATION_MAX_SESSIONS_PER_ROOM=5
TRANSLATION_AUDIO_SAMPLE_RATE=24000
TRANSLATION_SILENCE_TIMEOUT_MS=5000
TRANSLATION_MAX_UTTERANCE_SECONDS=30

# ──── Caption routing ────
CAPTION_STORAGE_ENABLED=false
CAPTION_RETENTION_DAYS=0

# ──── JWT ────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ──── Worker service tokens ────
CAPTION_WORKER_SERVICE_TOKEN=change-me-worker-service-token

# ──── Invitations ────
INVITE_DEFAULT_EXPIRE_HOURS=24
INVITE_MAX_USES=1

# ──── Frontend ────
NEXT_PUBLIC_LIVEKIT_WS_URL=ws://localhost:7880
NEXT_PUBLIC_API_URL=http://localhost:8000

# ──── CORS ────
CORS_ORIGINS=http://localhost:3000,https://meet.example.com
